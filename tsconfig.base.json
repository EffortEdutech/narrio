{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "preserve",
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@narrio/api": ["packages/api/src/index.ts"],
      "@narrio/ai": ["packages/ai/src/index.ts"],
      "@narrio/db": ["packages/db/src/index.ts"],
      "@narrio/ui": ["packages/ui/src/index.tsx"]
    },
    "allowJs": false,
    "noEmit": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "skipLibCheck": true
  }
}
