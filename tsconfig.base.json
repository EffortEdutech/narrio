{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "preserve",
    "allowJs": false,
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@narrio/api": [
        "packages/api/src/index.ts"
      ],
      "@narrio/db": [
        "packages/db/src/index.ts"
      ],
      "@narrio/ui": [
        "packages/ui/src/index.tsx"
      ],
      "@narrio/ai": [
        "packages/ai/src/index.ts"
      ]
    }
  }
}
