    "typecheck": "turbo run typecheck",
    "dev:marketing": "pnpm --filter @narrio/marketing dev"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "turbo": "^2.0.0",
    "typescript": "^5.8.0"
  }
}
